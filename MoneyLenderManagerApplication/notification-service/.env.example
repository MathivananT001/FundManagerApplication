# Notification Service Environment Variables
ENVIRONMENT=dev
AWS_REGION=ap-south-1
SNS_SMS_SENDER_ID=MLMFund
SQS_NOTIFICATION_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/ACCOUNT_ID/mlm-notification-queue-dev
